SOURCE_DIRS=/path/to/audio-folder
OUTPUT_DIRS=./output
INPUT_OUTPUT_PAIRS=[{"input":"/inputs/input-001","output":"/outputs/output-001"}]
WHISPER_MODEL=base
WHISPER_OUTPUT_FORMAT=all
WHISPER_LANGUAGE=
WHISPER_TASK=transcribe
WHISPER_DEVICE=auto
WHISPER_DOWNLOAD_DEVICE=cpu
WHISPER_FP16=auto
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_VERBOSE=true
FINGERPRINT_MODE=metadata
LOCAL_STAGING=false
LOCAL_STAGING_DIR=/tmp/auto-whisper-staging
OVERALL_OUTPUT_ENABLED=true
OVERALL_OUTPUT_DIR=/overall-output
SAFE_OUTPUT_FILENAMES=auto
SUPPORTED_EXTENSIONS=.mp3,.wav,.m4a,.mp4,.mov,.mkv,.webm,.flac,.ogg,.aac,.wma
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
PYANNOTE_AUTH_TOKEN=
PYANNOTE_METRICS_ENABLED=0
DIARIZATION_BACKEND=pyannote
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
DIARIZATION_VERBOSE=false
DIARIZATION_PROGRESS=
DIARIZATION_TF32=false
DIARIZATION_OOM_FALLBACK=cpu
DIARIZATION_AUDIO_PREPROCESS=always
DIARIZATION_AUDIO_PREPROCESS_DIR=/tmp/auto-whisper-diarization
DIARIZATION_MIN_OVERLAP_RATIO=0.3
DIARIZATION_NUM_SPEAKERS=
DIARIZATION_MIN_SPEAKERS=
DIARIZATION_MAX_SPEAKERS=
DIARIZATION_OUTPUT_DIR=/app/output_pyannote
DIARIZATION_OVERALL_OUTPUT_DIR=/app/output_pyannote_overall
DIARIZATION_CACHE_DIR=/app/state/diarization-cache
HF_HOME=/cache/huggingface
TORCH_HOME=/cache/torch
