FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg git \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip \
    && python -m pip install --index-url https://download.pytorch.org/whl/cpu torch==2.5.1+cpu \
    && python -m pip install openai-whisper

WORKDIR /app
COPY scripts/transcribe.py /app/transcribe.py
COPY scripts/download_model.py /app/download_model.py

CMD ["python", "/app/transcribe.py"]
